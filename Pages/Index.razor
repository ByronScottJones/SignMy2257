@page "/"

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="jumbotron">
                <h1 class="display-4">FBI Form 2257 System</h1>
                <p class="lead">Secure Form Processing for Adult Industry Compliance</p>
                <hr class="my-4">
                <p>This system helps producers and performers manage Form 2257 submissions in compliance with federal law.</p>
            </div>

            <div class="row mt-5">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fas fa-briefcase"></i> For Producers</h5>
                            <p class="card-text">Create a new Form 2257 by entering production information and generate a secure link for your performers.</p>
                            <a href="/form" class="btn btn-primary">Create Producer Form</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fas fa-user"></i> For Performers</h5>
                            <p class="card-text">If a producer has given you a form link, click below to access it and complete your information.</p>
                            <a href="/form" class="btn btn-success">Complete Performer Form</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-5 p-4 bg-light rounded">
                <h5>How It Works</h5>
                <ol>
                    <li><strong>Producer Creates Form:</strong> Producer enters their business information</li>
                    <li><strong>Share Link:</strong> Producer gets a unique link to share with performers</li>
                    <li><strong>Performer Completes Form:</strong> Performer opens link and fills in their information with ID photos</li>
                    <li><strong>Generate PDF:</strong> System creates compliant Form 2257 PDF</li>
                    <li><strong>Download & Archive:</strong> Both parties have copies for their records</li>
                </ol>
            </div>

            <div class="mt-4 p-3 bg-warning text-dark rounded">
                <strong>⚠️ Legal Notice:</strong> This system helps with Form 2257 compliance as required under 18 U.S.C. § 2257. Users are responsible for ensuring all information is accurate and truthful. Violations of federal law may result in severe penalties.
            </div>
        </div>
    </div>
</div>
