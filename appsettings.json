{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Storage": {
    "BasePath": "/app/data"
  },
  "RateLimiting": {
    "Enabled": true,
    "RequestsPerWindow": 100,
    "WindowSizeInSeconds": 60
  }
}
